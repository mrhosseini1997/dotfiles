{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(basename *)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(file *)",
      "Bash(ls *)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(stat *)",
      "Bash(tree *)",
      "Bash(pwd *)",
      "Bash(whoami *)",
      "Bash(hostname *)",
      "Bash(uname *)",
      "Bash(date *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(ps *)",
      "Bash(id *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(cut *)",
      "Bash(sort *)",
      "Bash(tr *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git blame*)",
      "Bash(gh *)",
      "Bash(brew info *)",
      "Bash(brew list *)",
      "Bash(docker ps*)",
      "Bash(docker images*)",
      "Bash(kubectl get*)",
      "Bash(kubectl describe*)",
      "Bash(kubectl logs*)",
      "Bash(terraform plan*)",
      "Bash(terraform validate*)",
      "Bash(curl -s*)",
      "Bash(curl -I*)",
      "Bash(mkdir *)",
      "WebFetch(domain:*)",
      "WebSearch"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Bash(dd *)",
      "Bash(diskutil *)",
      "Bash(mkfs *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(sudo rm -rf /*)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git reset --hard*)",
      "Bash(gh pr merge *)",
      "Bash(docker push *)",
      "Bash(npm publish *)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(kubectl apply*)",
      "Bash(kubectl delete*)"
    ],
    "defaultMode": "auto"
  }
}
