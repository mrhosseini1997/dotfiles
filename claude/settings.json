{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(basename *)",
      "Bash(diff *)",
      "Bash(dirname *)",
      "Bash(file *)",
      "Bash(ls *)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(stat *)",
      "Bash(tree *)",
      "Bash(pwd *)",
      "Bash(whoami *)",
      "Bash(hostname *)",
      "Bash(uname *)",
      "Bash(date *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(ps *)",
      "Bash(id *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(cut *)",
      "Bash(sort *)",
      "Bash(tr *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git blame*)",
      "Bash(gh *)",
      "Bash(brew info *)",
      "Bash(brew list *)",
      "Bash(docker ps*)",
      "Bash(docker images*)",
      "Bash(kubectl get*)",
      "Bash(kubectl describe*)",
      "Bash(kubectl logs*)",
      "Bash(terraform plan*)",
      "Bash(terraform validate*)",
      "Bash(curl -s*)",
      "Bash(curl -I*)",
      "Bash(mkdir *)",
      "WebFetch(domain:*)",
      "WebSearch"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Bash(dd *)",
      "Bash(diskutil *)",
      "Bash(mkfs *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(sudo rm -rf /*)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git reset --hard*)",
      "Bash(gh pr merge *)",
      "Bash(docker push *)",
      "Bash(npm publish *)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(kubectl apply*)",
      "Bash(kubectl delete*)"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "enabledPlugins": {
    "python-library-complete@python-library-dev": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "terraform-skill@antonbabenko": true,
    "superpowers@superpowers-marketplace": true,
    "clangd-lsp@claude-plugins-official": true,
    "lsp@dotfiles": true
  },
  "extraKnownMarketplaces": {
    "python-library-dev": {
      "source": {
        "source": "github",
        "repo": "wdm0006/python-skills"
      }
    },
    "antonbabenko": {
      "source": {
        "source": "github",
        "repo": "antonbabenko/terraform-skill"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "dotfiles": {
      "source": {
        "source": "directory",
        "path": "/Users/mohammadhosseini/dotfiles/claude/lsp-marketplace"
      }
    }
  },
  "skipAutoPermissionPrompt": true
}
